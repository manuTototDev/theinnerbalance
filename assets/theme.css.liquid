/* The Inner Balance Theme CSS */
:root {
  --color-bg: {{ settings.color_background }};
  --color-text: {{ settings.color_foreground }};
  --color-text-secondary: {{ settings.color_secondary_text }};
  --color-button-bg: {{ settings.color_button_bg }};
  --color-button-text: {{ settings.color_button_text }};
  --color-border: {{ settings.color_border }};
  --color-announcement-bg: {{ settings.color_announcement_bg }};
  --color-announcement-text: {{ settings.color_announcement_text }};
  
  --font-heading: {{ settings.heading_font }};
  --font-body: 'Inter', sans-serif;
  
  --base-size: {{ settings.base_font_size }}px;
}

body {
  font-family: var(--font-body);
  font-size: var(--base-size);
  background-color: var(--color-bg);
  color: var(--color-text);
  margin: 0;
  padding: 0;
  line-height: 1.5;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  margin-top: 0;
}

a {
  color: inherit;
  text-decoration: none;
}

.visually-hidden {
  position: absolute !important;
  overflow: hidden;
  clip: rect(0 0 0 0);
  height: 1px;
  width: 1px;
  margin: -1px;
  padding: 0;
  border: 0;
}

.btn {
  display: inline-block;
  padding: 10px 20px;
  text-align: center;
  cursor: pointer;
  border: none;
  font-family: var(--font-body);
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn--primary {
  background-color: var(--color-button-bg);
  color: var(--color-button-text);
}

.btn--primary:hover {
  opacity: 0.9;
}

.btn--outline {
  background-color: transparent;
  color: var(--color-button-bg);
  border: 1px solid var(--color-button-bg);
}

.btn--full {
  width: 100%;
}

/* Header */
.header {
  padding: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--color-border);
}

/* Image Banner / Hero */
.hero {
  position: relative;
  text-align: center;
  padding: 60px 20px;
  background-color: var(--color-bg);
}
.hero h2 {
  font-size: 2.5rem;
  margin-bottom: 20px;
}

/* Marquee */
.marquee-container {
  background: var(--color-button-bg);
  color: var(--color-button-text);
  padding: 10px 0;
  overflow: hidden;
  white-space: nowrap;
}

/* Footer */
.footer {
  padding: 40px 20px;
  text-align: center;
  border-top: 1px solid var(--color-border);
  font-size: 0.9rem;
}

/* Drawers & Overlays */
.search-overlay, .mobile-menu, .mini-cart {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.search-overlay.is-open, .mobile-menu.is-open, .mini-cart.is-open {
  visibility: visible;
  opacity: 1;
}

.search-overlay__backdrop, .mobile-menu__backdrop, .mini-cart__backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.search-overlay__panel, .mobile-menu__drawer, .mini-cart__drawer {
  position: absolute;
  background: var(--color-bg);
  box-shadow: 0 0 20px rgba(0,0,0,0.1);
  transition: transform 0.3s ease;
}

/* Specific Drawer Positions */
.search-overlay__panel {
  top: 0; left: 0; width: 100%; padding: 30px;
  transform: translateY(-100%);
}
.search-overlay.is-open .search-overlay__panel { transform: translateY(0); }

.mobile-menu__drawer {
  top: 0; left: 0; width: 300px; height: 100%; max-width: 80%; padding: 20px;
  transform: translateX(-100%);
  display: flex; flex-direction: column;
}
.mobile-menu.is-open .mobile-menu__drawer { transform: translateX(0); }

.mini-cart__drawer {
  top: 0; right: 0; width: 400px; height: 100%; max-width: 90%; padding: 20px;
  transform: translateX(100%);
  display: flex; flex-direction: column;
}
.mini-cart.is-open .mini-cart__drawer { transform: translateX(0); }

/* Drawer Internals */
.mobile-menu__list { list-style: none; padding: 0; margin: 20px 0; flex-grow: 1;}
.mobile-menu__list li { margin-bottom: 15px; }
.mobile-menu__list a { font-size: 1.2rem; font-weight: 500; }
.mobile-menu__close, .mini-cart__close, .search-overlay__close {
  background: none; border: none; cursor: pointer; padding: 5px; float: right;
}
.mini-cart__body { flex-grow: 1; overflow-y: auto; padding: 20px 0; }
.mini-cart__footer { padding-top: 20px; border-top: 1px solid var(--color-border); }

