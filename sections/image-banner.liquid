<div class="hero-full" style="
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background-color: #EEEEEE;
  {% if section.settings.image != blank %}
    background-image: url('{{ section.settings.image | image_url: width: 1500 }}');
  {% else %}
    background-image: linear-gradient(#CCCCCC, #EEEEEE);
  {% endif %}
  background-size: cover;
  background-position: center;
  color: {{ section.settings.text_color }};
">
  <!-- Overlay for better text readability -->
  <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

  <div class="hero-full__content" style="position: relative; z-index: 1; padding: 20px; max-width: 800px;">
    {%- if section.settings.heading != blank -%}
      <h2 style="font-size: 3rem; margin-bottom: 20px; line-height: 1.2;">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    
    {%- if section.settings.subheading != blank -%}
      <p style="font-size: 1.2rem; margin-bottom: 30px;">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
      {%- if section.settings.button_label_1 != blank -%}
        <a href="{{ section.settings.button_link_1 }}" class="btn btn--primary" style="background-color: #333333; color: #FFFFFF; border-radius: 4px; padding: 15px 40px; font-weight: 600; text-transform: uppercase;">
          {{ section.settings.button_label_1 }}
        </a>
      {%- endif -%}
      
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--outline" style="border: 2px solid #333333; color: #333333; background-color: #FFFFFF; border-radius: 4px; padding: 15px 40px; font-weight: 600; text-transform: uppercase;">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Full Screen Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image (Vertical recommended for mobile)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Overlay Opacity",
      "default": 10
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wireframe Title"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Description text goes here for the hero section."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Button Text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Button Link",
      "default": "/pages/about-us"
    }
  ],
  "presets": [
    {
      "name": "Full Screen Banner"
    }
  ]
}
{% endschema %}
