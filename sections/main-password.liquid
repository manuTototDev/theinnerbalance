<div class="password-main">
  <h1 style="font-size: 2rem; margin-bottom: 20px;">{{ shop.name }}</h1>
  <p style="margin-bottom: 30px; color: var(--color-text-secondary);">Próximamente estaremos en línea. Esta tienda está en desarrollo.</p>
  
  {% form 'storefront_password', class: 'password-form' %}
    {{ form.errors | default_errors }}
    <div style="display:flex; gap:10px;">
      <input type="password" name="password" id="Password" placeholder="Contraseña de la tienda" style="flex:1; padding:10px; border:1px solid var(--color-border); border-radius:4px;">
      <button type="submit" name="commit" class="btn btn--primary" style="background:#333; color:#fff; padding:10px 20px; border:none; border-radius:4px; cursor:pointer;">Entrar</button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": []
}
{% endschema %}
