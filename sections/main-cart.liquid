<div style="padding: 40px 20px; max-width: 800px; margin: 0 auto;">
  <h1 style="text-align: center; margin-bottom: 40px;">Tu Carrito</h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      {% for item in cart.items %}
        <div style="display: flex; gap: 20px; border-bottom: 1px solid #eee; padding-bottom: 20px; margin-bottom: 20px; align-items: center;">
          <div style="width: 100px;">
            {% if item.image %}
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" style="width: 100%;">
            {% endif %}
          </div>
          <div style="flex-grow: 1;">
            <h3 style="margin: 0 0 10px;"><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
            <div>{{ item.price | money }}</div>
          </div>
          <div>
            <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" style="width: 60px; padding: 5px;">
          </div>
          <div style="font-weight: bold;">
            {{ item.line_price | money }}
          </div>
          <div>
            <a href="{{ item.url_to_remove }}" style="color: red; text-decoration: none;">&times;</a>
          </div>
        </div>
      {% endfor %}

      <div style="text-align: right; margin-top: 30px;">
        <p style="font-size: 1.2rem;">Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
        <div style="margin-top: 20px;">
          <button type="submit" name="update" class="btn btn--outline">Actualizar Carrito</button>
          <button type="submit" name="checkout" class="btn btn--primary" style="margin-left: 10px;">Proceder al Pago</button>
        </div>
      </div>
    </form>
  {% else %}
    <div style="text-align: center;">
      <p>Tu carrito está vacío.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-top: 20px;">Seguir Comprando</a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
