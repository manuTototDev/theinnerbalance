<div class="instagram-feed" style="padding: 60px 20px; text-align: center; border-top: 1px solid var(--color-border); background: var(--color-bg);">
  <h2 style="color: var(--color-text); margin-bottom: 30px;">Instagram Feed Wireframe</h2>
  
  <div style="display: flex; gap: 15px; justify-content: center; overflow-x: auto; padding-bottom: 20px;">
    {% for i in (1..4) %}
      <div style="width: 250px; height: 250px; background: var(--color-secondary-bg); border: 1px solid var(--color-border); border-radius: 4px; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
        <span style="color: var(--color-text-secondary);">Instagram Post {{ i }}</span>
      </div>
    {% endfor %}
  </div>

  <a href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" class="btn btn--outline" style="margin-top: 20px; border: 2px solid var(--color-button-bg); color: var(--color-button-bg); border-radius: 4px; padding: 10px 30px; text-transform: uppercase;">
    View Profile Button
  </a>
</div>

{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram Profile URL"
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed"
    }
  ]
}
{% endschema %}
