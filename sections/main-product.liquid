<div class="product-page" style="padding: 40px 20px; max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 40px;">
  <div class="product-page__media" style="flex: 1; min-width: 300px;">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" style="width: 100%; height: auto; border-radius: 4px; border: 1px solid var(--color-border);">
    {% else %}
      <div style="width: 100%; height: 500px; background: #EEEEEE; border: 1px solid #CCCCCC; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #999;">Product Image Placeholder</div>
    {% endif %}
  </div>

  <div class="product-page__info" style="flex: 1; min-width: 300px;">
    <h1 style="font-size: 2.5rem; color: var(--color-text); margin-bottom: 10px;">{{ product.title | default: 'Product Title Wireframe' }}</h1>
    <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: 20px; color: var(--color-text-secondary);">
      {% if product != blank %}{{ product.price | money }}{% else %}$00.00{% endif %}
    </div>

    {%- if product != blank -%}
      {%- form 'product', product, class: 'product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div style="margin-bottom: 20px;">
          <label for="Quantity" style="font-weight: 500;">Quantity</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1" style="width: 60px; padding: 10px; margin-left: 10px; border: 1px solid #CCCCCC; border-radius: 4px;">
        </div>

        <button type="submit" class="btn btn--primary btn--full" style="padding: 15px; font-size: 1.1rem; background-color: #333333; color: white; border: none; cursor: pointer; border-radius: 4px; text-transform: uppercase;">
          Add to Cart
        </button>
      {%- endform -%}
    {%- else -%}
      <div style="margin-bottom: 20px;">
        <label for="Quantity" style="font-weight: 500;">Quantity</label>
        <input type="number" id="Quantity" value="1" min="1" style="width: 60px; padding: 10px; margin-left: 10px; border: 1px solid #CCCCCC; border-radius: 4px;">
      </div>
      <button type="button" class="btn btn--primary btn--full" style="padding: 15px; font-size: 1.1rem; background-color: #333333; color: white; border: none; border-radius: 4px; text-transform: uppercase;">
        Add to Cart
      </button>
    {%- endif -%}

    <div class="product-page__description" style="margin-top: 40px; line-height: 1.6; color: var(--color-text-secondary);">
      {% if product.description != blank %}
        {{ product.description }}
      {% else %}
        <p>Product description placeholder. This is where details about the features, technical specifications, and other relevant information will go.</p>
        <ul>
          <li>Feature 1</li>
          <li>Feature 2</li>
          <li>Feature 3</li>
        </ul>
      {% endif %}
    </div>
    
    <!-- Learning Center / Support links from Journey Map -->
    <div style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #CCCCCC;">
      <a href="#" style="display: block; padding: 15px 0; font-weight: 600; border-bottom: 1px solid #EEEEEE; color: var(--color-text);">Learning Center →</a>
      <a href="#" style="display: block; padding: 15px 0; font-weight: 600; border-bottom: 1px solid #EEEEEE; color: var(--color-text);">Soporte →</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Information",
  "settings": []
}
{% endschema %}
