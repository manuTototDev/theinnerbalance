<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Coming Soon - {{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password" style="display:flex; flex-direction:column; min-height:100vh; align-items:center; justify-content:center; text-align:center; background-color: var(--color-bg); color: var(--color-text); padding: 20px;">
    <main id="MainContent" role="main" style="width: 100%; max-width: 500px; padding: 40px; border: 1px solid var(--color-border); border-radius: 4px; background: #fff;">
      {{ content_for_layout }}
    </main>
  </body>
</html>
